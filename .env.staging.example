# =============================================================================
# Inventaire SI — Environnement STAGING (.env)
# =============================================================================
# À copier en `/opt/inventaire/staging/.env` sur le serveur (JAMAIS commité).
# Générer chaque secret avec :  openssl rand -base64 32   (64 pour les JWT)
# Les secrets DOIVENT être DISTINCTS de la prod (isolation totale).
# =============================================================================

# --- Compose / images -------------------------------------------------------
COMPOSE_PROJECT_NAME=inventaire-staging
# Tag d'image GHCR à déployer (la CI pousse `staging` sur push branche staging)
IMAGE_TAG=staging

# --- PostgreSQL (DB isolée de la prod) --------------------------------------
POSTGRES_DB=inventaire
POSTGRES_USER=inventaire_user
POSTGRES_PASSWORD=CHANGER_openssl_rand_base64_32

# --- API --------------------------------------------------------------------
DATABASE_URL=postgresql://inventaire_user:CHANGER_MEME_QUE_POSTGRES_PASSWORD@postgres:5432/inventaire?connection_limit=10&pool_timeout=30
REDIS_PASSWORD=CHANGER_openssl_rand_base64_32
JWT_ACCESS_SECRET=CHANGER_openssl_rand_base64_64
JWT_REFRESH_SECRET=CHANGER_openssl_rand_base64_64
CORS_ORIGIN=https://staging.tillyinventaire.ti
SIGNATURES_DIR=/app/uploads/signatures

# Sentry (optionnel — laisser vide pour désactiver)
SENTRY_DSN=
SENTRY_ENVIRONMENT=staging
SENTRY_TRACES_SAMPLE_RATE=0.1

# --- Grafana / monitoring ---------------------------------------------------
GRAFANA_PASSWORD=CHANGER_openssl_rand_base64_24
GF_SERVER_ROOT_URL=https://staging.tillyinventaire.ti/grafana/

# --- SMTP (Alertmanager) ----------------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=25
SMTP_FROM=alertes-staging@tillyinventaire.ti
SMTP_USERNAME=
SMTP_PASSWORD=

# =============================================================================
# NOTE : les variables VITE_* (frontend) NE sont PAS utilisées ici — elles sont
# bakées dans l'image web au BUILD par la CI (.github/workflows/build-images.yml).
# =============================================================================
